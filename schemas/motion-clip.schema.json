{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.blender-threejs-bakes/schemas/motion-clip.schema.json",
  "title": "Sampled world-space motion clip",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "space", "sample_interval_s", "duration_s", "frames"],
  "properties": {
    "schema": { "const": "motion-clip/1" },
    "space": { "const": "threejs_yup" },
    "sample_interval_s": { "type": "number", "exclusiveMinimum": 0 },
    "duration_s": { "type": "number", "minimum": 0 },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "time_s", "entities"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "time_s": { "type": "number", "minimum": 0 },
          "entities": { "type": "object" }
        }
      }
    }
  }
}
