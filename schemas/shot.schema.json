{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BenKnill/blender-threejs-bakes/schemas/shot.schema.json",
  "title": "Blender Three.js Bake Shot Package",
  "description": "Stable first/last keyframe package for downstream image-to-video models.",
  "type": "object",
  "required": [
    "schema",
    "shot_id",
    "prompt",
    "negative",
    "duration_s",
    "fps_target",
    "model_hint",
    "source_layouts",
    "frames",
    "render_metadata"
  ],
  "properties": {
    "schema": { "const": 1 },
    "shot_id": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string" },
    "negative": { "type": "string" },
    "subject": { "type": "string" },
    "motion_notes": { "type": "string" },
    "camera_move": { "type": "object" },
    "duration_s": { "type": "number", "exclusiveMinimum": 0 },
    "fps_target": { "type": "integer", "minimum": 1 },
    "model_hint": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "source_layouts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "frames": {
      "type": "object",
      "required": ["first"],
      "properties": {
        "first": { "$ref": "#/$defs/frame" },
        "last": { "$ref": "#/$defs/frame" }
      }
    },
    "render_metadata": {
      "type": "object",
      "required": ["generated_at", "generator", "shot_dir", "manifest", "renders"],
      "properties": {
        "generated_at": { "type": "string", "minLength": 1 },
        "generator": { "type": "string", "minLength": 1 },
        "shot_dir": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 },
        "render_overrides": { "type": "object" },
        "layout_render": { "type": "object" },
        "renders": { "type": "array", "items": { "type": "object" } }
      }
    }
  },
  "$defs": {
    "frame": {
      "type": "object",
      "required": ["path", "pose", "bytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "pose": { "enum": ["base", "a", "b"] },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
