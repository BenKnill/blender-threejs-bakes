{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.blender-threejs-bakes/schemas/scene-state.schema.json",
  "title": "Continuous scene state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "space", "entities"],
  "properties": {
    "schema": { "const": "scene-state/1" },
    "space": { "const": "threejs_yup" },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entity" }
    }
  },
  "$defs": {
    "vec3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "quat": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "number" }
    },
    "pose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position_m", "orientation_xyzw"],
      "properties": {
        "position_m": { "$ref": "#/$defs/vec3" },
        "orientation_xyzw": { "$ref": "#/$defs/quat" },
        "scale_xyz": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linear_velocity_m_s", "angular_velocity_rad_s"],
      "properties": {
        "linear_velocity_m_s": { "$ref": "#/$defs/vec3" },
        "angular_velocity_rad_s": { "$ref": "#/$defs/vec3" }
      }
    },
    "physics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body_type", "collider"],
      "properties": {
        "body_type": { "enum": ["static", "dynamic", "kinematic"] },
        "collider": { "type": "string", "minLength": 1 },
        "density_kg_m3": { "type": "number", "exclusiveMinimum": 0 },
        "friction": { "type": "number", "minimum": 0 },
        "restitution": { "type": "number", "minimum": 0, "maximum": 1 },
        "linear_damping": { "type": "number", "minimum": 0 },
        "angular_damping": { "type": "number", "minimum": 0 },
        "gravity_scale": { "type": "number" },
        "sleep_threshold_m_s": { "type": "number", "minimum": 0 },
        "enable_sleep": { "type": "boolean" },
        "is_awake": { "type": "boolean" },
        "is_bullet": { "type": "boolean" },
        "is_enabled": { "type": "boolean" },
        "allow_fast_rotation": { "type": "boolean" },
        "enable_contact_recycling": { "type": "boolean" },
        "motion_locks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "linear_x": { "type": "boolean" },
            "linear_y": { "type": "boolean" },
            "linear_z": { "type": "boolean" },
            "angular_x": { "type": "boolean" },
            "angular_y": { "type": "boolean" },
            "angular_z": { "type": "boolean" }
          }
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id"],
      "properties": {
        "asset_id": { "type": "string", "minLength": 1 }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["focal_length_mm", "sensor_width_mm"],
      "properties": {
        "focal_length_mm": { "type": "number", "exclusiveMinimum": 0 },
        "sensor_width_mm": { "type": "number", "exclusiveMinimum": 0 },
        "focus_distance_m": { "type": "number", "exclusiveMinimum": 0 },
        "aperture_fstop": { "type": "number", "exclusiveMinimum": 0 },
        "exposure_stops": { "type": "number" },
        "look_at": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_position_m"],
          "properties": {
            "target_position_m": { "$ref": "#/$defs/vec3" },
            "up_direction_xyz": { "$ref": "#/$defs/vec3" }
          }
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "frame", "pose", "motion"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "kind": { "enum": ["asset", "camera"] },
        "frame": { "type": "string", "minLength": 1 },
        "pose": { "$ref": "#/$defs/pose" },
        "motion": { "$ref": "#/$defs/motion" },
        "asset": { "$ref": "#/$defs/asset" },
        "camera": { "$ref": "#/$defs/camera" },
        "physics": { "$ref": "#/$defs/physics" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "asset" } } },
          "then": { "required": ["asset"] }
        },
        {
          "if": { "properties": { "kind": { "const": "camera" } } },
          "then": { "required": ["camera"] }
        }
      ]
    }
  }
}
