{
  "name": "blender-threejs-bakes",
  "private": true,
  "type": "module",
  "description": "Tooling-only manifest. The editor itself has NO build step and ships vendored ESM.",
  "scripts": {
    "prepare": "lefthook install",
    "serve": "./scripts/serve.sh",
    "lint": "eslint editor physics/labs/contact_shell/demo/main.js && prettier --check 'editor/**/*.{js,css,html}' 'physics/labs/contact_shell/demo/**/*.{js,css,html,json}'",
    "format": "prettier --write 'editor/**/*.{js,css,html}' 'physics/labs/contact_shell/demo/**/*.{js,css,html,json}'"
  },
  "devDependencies": {
    "eslint": "^9",
    "globals": "^15",
    "lefthook": "^1",
    "prettier": "^3"
  }
}
